# CMake build output
build/
cmake-build-*/

# Plugin artifacts (regenerated by CI / local build, not tracked in VCS)
*.scx
*.so
*.dll

# Editor scratch
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# external_libraries/ holds git submodules pinned in `.gitmodules`. Local
# clones are managed by `git submodule update --init` — no extra ignore rules
# needed here. (Step 2.1 used a placeholder ignore that was removed once the
# real submodules were added in Step 2.2.)
