.vscode/**
.vscode-test/**
.git/**
src/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/tsconfig.tsbuildinfo
**/.eslintrc.json
**/.eslintrc.cjs
**/.gitignore
**/*.map
**/*.ts
**/*.d.ts
**/*.d.ts.map
*.vsix
*.tgz
../../**
../engine/**
# packages/sc-link-audio/ is a sibling workspace member that ships as a
# separate GPL-2.0-or-later artifact (Step 2 / Step 4 of Epic #187), not
# as part of the .vsix. Without this exclusion vsce 3.x walks the workspace
# and tries to package the sibling, which fails with
# "invalid relative path: extension/../sc-link-audio/.gitignore".
../sc-link-audio/**
engine/package-lock.json
engine/package.json
# Keep built engine, SuperCollider files, and runtime dependencies
!engine/dist/**
!engine/supercollider/**
!engine/node_modules/**
# Keep bundled scsynth (binary + plugins + libsndfile + LICENSE/NOTICE)
!engine/scsynth/**
# Keep legal templates (used by extract-scsynth-bundle.sh)
!legal/**
